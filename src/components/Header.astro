---
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container header-container">
    <a href="/" class="logo" aria-label="Drawing Prompt Generator Home">
      <span class="logo-accent">Drawing</span>PromptGenerator
    </a>

    <div class="header-right">
      <!-- Desktop Navigation -->
      <nav class="desktop-nav" aria-label="Primary Navigation">
        <ul class="nav-list">
          <li>
            <a href="/" class={currentPath === '/' ? 'active' : ''}>Home</a>
          </li>
          <li>
            <a href="/categories" class={currentPath.startsWith('/categories') ? 'active' : ''}>Categories</a>
          </li>
          <li>
            <a href="/random" class={currentPath.startsWith('/random') ? 'active' : ''}>Random Prompt</a>
          </li>
          <li>
            <a href="/about" class={currentPath.startsWith('/about') ? 'active' : ''}>About</a>
          </li>
          <li>
            <a href="/faq" class={currentPath.startsWith('/faq') ? 'active' : ''}>FAQ</a>
          </li>
        </ul>
      </nav>

      <!-- Theme & Menu Actions -->
      <div class="header-actions">
        <!-- Theme Toggle Button (WCAG 44px Touch Target) -->
        <button 
          id="theme-toggle" 
          class="theme-toggle-btn" 
          aria-label="Switch to dark theme"
          title="Toggle color theme"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="theme-icon-sun" aria-hidden="true">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="M4.93 4.93l1.41 1.41"></path>
            <path d="M17.66 17.66l1.41 1.41"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
            <path d="M6.34 17.66l-1.41 1.41"></path>
            <path d="M19.07 4.93l-1.41 1.41"></path>
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="theme-icon-moon" aria-hidden="true">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
          </svg>
        </button>

        <!-- Mobile Navigation Toggle (WCAG 44px Touch Target) -->
        <button 
          class="mobile-nav-toggle" 
          aria-expanded="false" 
          aria-controls="mobile-menu"
          aria-label="Toggle navigation menu"
        >
          <span class="bar" aria-hidden="true"></span>
          <span class="bar" aria-hidden="true"></span>
          <span class="bar" aria-hidden="true"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Navigation Menu -->
  <div class="mobile-menu-container" id="mobile-menu" aria-hidden="true">
    <nav class="mobile-nav" aria-label="Mobile Navigation">
      <ul class="mobile-nav-list">
        <li>
          <a href="/" class={currentPath === '/' ? 'active' : ''}>Home</a>
        </li>
        <li>
          <a href="/categories" class={currentPath.startsWith('/categories') ? 'active' : ''}>Categories</a>
        </li>
        <li>
          <a href="/random" class={currentPath.startsWith('/random') ? 'active' : ''}>Random Prompt</a>
        </li>
        <li>
          <a href="/about" class={currentPath.startsWith('/about') ? 'active' : ''}>About</a>
        </li>
        <li>
          <a href="/faq" class={currentPath.startsWith('/faq') ? 'active' : ''}>FAQ</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  // Mobile menu toggle script
  const toggleBtn = document.querySelector('.mobile-nav-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  if (toggleBtn && mobileMenu) {
    toggleBtn.addEventListener('click', () => {
      const isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';
      
      toggleBtn.setAttribute('aria-expanded', (!isExpanded).toString());
      toggleBtn.classList.toggle('open');
      
      mobileMenu.setAttribute('aria-hidden', isExpanded.toString());
      mobileMenu.classList.toggle('active');
      
      // Prevent body scrolling when mobile menu is open
      document.body.style.overflow = isExpanded ? 'auto' : 'hidden';
    });

    // Close menu when clicking a link
    const mobileLinks = mobileMenu.querySelectorAll('a');
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        toggleBtn.setAttribute('aria-expanded', 'false');
        toggleBtn.classList.remove('open');
        mobileMenu.setAttribute('aria-hidden', 'true');
        mobileMenu.classList.remove('active');
        document.body.style.overflow = 'auto';
      });
    });
  }

  // Dark/Light Theme Switcher Script
  const themeToggle = document.getElementById('theme-toggle');
  
  if (themeToggle) {
    // Set active accessibility aria-label based on state loaded by FOUC script
    const updateAriaLabel = () => {
      const isDark = document.documentElement.classList.contains('dark');
      themeToggle.setAttribute('aria-label', isDark ? 'Switch to light theme' : 'Switch to dark theme');
    };
    
    // Run on load
    updateAriaLabel();

    themeToggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateAriaLabel();
    });
  }
</script>

<style>
  .site-header {
    height: 76px; /* Expanded for better vertical breathing space */
    display: flex;
    align-items: center;
    background-color: rgba(250, 250, 252, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .logo {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(1.15rem, 3.5vw, 1.35rem);
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.03em;
    display: flex;
    align-items: center;
    min-height: 44px; /* Accessible touch target */
  }

  .logo-accent {
    color: var(--primary);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav-list {
    display: flex;
    gap: 28px;
    list-style: none;
  }

  .nav-list a {
    color: var(--text-muted);
    font-weight: 500;
    font-size: 0.95rem;
    position: relative;
    padding: 10px 0;
    display: inline-flex;
    align-items: center;
    min-height: 44px; /* Accessible touch target */
  }

  .nav-list a:hover,
  .nav-list a.active {
    color: var(--primary);
  }

  /* Animated underline effect */
  .nav-list a::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--primary);
    transition: var(--transition-fast);
  }

  .nav-list a:hover::after,
  .nav-list a.active::after {
    width: 100%;
  }

  /* Theme Toggle Button */
  .theme-toggle-btn {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: transparent;
    border: 1px solid var(--border-color);
    color: var(--text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .theme-toggle-btn:hover {
    color: var(--primary);
    border-color: var(--primary);
    background-color: rgba(109, 94, 248, 0.05);
  }

  /* CSS Sun/Moon toggling */
  .theme-toggle-btn .theme-icon-sun {
    display: none;
  }
  .theme-toggle-btn .theme-icon-moon {
    display: block;
  }
  
  :global(html.dark) .theme-toggle-btn .theme-icon-sun {
    display: block;
  }
  :global(html.dark) .theme-toggle-btn .theme-icon-moon {
    display: none;
  }

  /* Mobile menu button styling */
  .mobile-nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 101;
    padding: 13px 10px; /* Expands to WCAG 44px box */
  }

  .mobile-nav-toggle .bar {
    width: 24px;
    height: 2px;
    background-color: var(--text);
    border-radius: 999px;
    transition: var(--transition-smooth);
    display: block;
  }

  /* Hamburger to Cross Animation */
  .mobile-nav-toggle.open .bar:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .mobile-nav-toggle.open .bar:nth-child(2) {
    opacity: 0;
  }

  .mobile-nav-toggle.open .bar:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Mobile navigation container styling */
  .mobile-menu-container {
    position: fixed;
    top: 76px;
    left: 0;
    width: 100%;
    height: calc(100vh - 76px);
    background-color: var(--card-bg);
    z-index: 99;
    padding: 40px 24px;
    transform: translateY(-100%);
    opacity: 0;
    visibility: hidden;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease, visibility 0.3s ease;
    border-top: 1px solid var(--border-color);
  }

  .mobile-menu-container.active {
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
  }

  .mobile-nav-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
    list-style: none;
  }

  .mobile-nav-list a {
    color: var(--text);
    font-size: 1.25rem;
    font-weight: 600;
    font-family: 'Outfit', sans-serif;
    display: block;
    padding: 10px 0;
    min-height: 44px; /* Accessible touch target */
  }

  .mobile-nav-list a.active {
    color: var(--primary);
  }

  /* Media Queries */
  @media (max-width: 768px) {
    .desktop-nav {
      display: none;
    }
    
    .header-right {
      gap: 16px;
    }
    
    .mobile-nav-toggle {
      display: flex;
    }
  }
</style>
