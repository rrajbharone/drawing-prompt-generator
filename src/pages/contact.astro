---
import Layout from '../layouts/Layout.astro';

const title = "Contact Us — Drawing Prompt Generator";
const description = "Get in touch with Drawing Prompt Generator. Send feedback, suggest drawing categories, report bugs, or request business inquiries.";
---

<Layout title={title} description={description}>
  <div class="contact-page">
    <div class="container container-narrow">
      <div class="text-center contact-header">
        <div class="badge badge-primary">Get In Touch</div>
        <h1 class="contact-title">Contact Us</h1>
        <p class="contact-subtitle">We would love to hear from you. Suggest prompts, report issues, or tell us how drawing prompts helped your art.</p>
      </div>

      <div class="grid grid-cols-2 contact-grid">
        <!-- Contact card 1 -->
        <div class="card contact-card">
          <div class="contact-icon">📧</div>
          <h3>Email Support</h3>
          <p>For general inquiries, technical assistance, or business partnerships, drop us an email.</p>
          <a href="mailto:support@drawingpromptgenerator.com" class="contact-link">support@drawingpromptgenerator.com</a>
        </div>

        <!-- Contact card 2 -->
        <div class="card contact-card">
          <div class="contact-icon">💡</div>
          <h3>Suggest Prompts</h3>
          <p>Have ideas for new character classes, environments, sci-fi descriptors, or monsters? Send them over!</p>
          <a href="mailto:feedback@drawingpromptgenerator.com" class="contact-link">feedback@drawingpromptgenerator.com</a>
        </div>
      </div>

      <!-- FAQ teaser -->
      <div class="card contact-faq-teaser text-center">
        <h3>Looking for quick answers?</h3>
        <p>Before emailing us, check our FAQ section for quick answers on licensing, commercial use, and art tips.</p>
        <a href="/faq" class="btn btn-secondary btn-sm">Read FAQs</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .contact-page {
    padding: 60px 0 80px 0;
  }

  .container-narrow {
    max-width: 800px;
  }

  .contact-header {
    margin-bottom: 48px;
  }

  .contact-title {
    font-size: 2.75rem;
    margin-top: 12px;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .contact-subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
  }

  .contact-grid {
    margin-bottom: 40px;
  }

  .contact-card {
    padding: 32px 24px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .contact-icon {
    font-size: 2.5rem;
    margin-bottom: 16px;
  }

  .contact-card h3 {
    font-size: 1.25rem;
    margin-bottom: 10px;
    color: var(--text);
  }

  .contact-card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
    flex-grow: 1;
    margin-bottom: 20px;
  }

  .contact-link {
    font-weight: 600;
    color: var(--primary);
    font-size: 0.95rem;
  }

  .contact-link:hover {
    color: var(--primary-hover);
    text-decoration: underline;
  }

  .contact-faq-teaser {
    padding: 30px;
    background-color: var(--background);
    border-color: var(--border-color);
  }

  .contact-faq-teaser h3 {
    font-size: 1.15rem;
    margin-bottom: 8px;
  }

  .contact-faq-teaser p {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  .contact-faq-teaser .btn {
    display: inline-flex;
    width: auto;
    padding: 8px 20px;
  }

  @media (max-width: 640px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }
</style>
