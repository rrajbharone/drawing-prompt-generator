---
import Layout from '../layouts/Layout.astro';

const title = "Disclaimer — Drawing Prompt Generator";
const description = "Read the legal disclaimer for Drawing Prompt Generator. Review content disclaimers, external links policy, and professional liabilities.";
---

<Layout title={title} description={description}>
  <div class="legal-page">
    <div class="container container-narrow">
      <div class="text-center legal-header">
        <h1 class="legal-title">Disclaimer</h1>
        <p class="legal-subtitle">Effective Date: June 26, 2026</p>
      </div>

      <div class="card legal-content-card">
        <p>
          The information contained on the Drawing Prompt Generator website (drawingpromptgenerator.com) is for general inspirational and educational purposes only.
        </p>

        <h2>1. Consent and Agreement</h2>
        <p>
          By using our website, you hereby consent to our disclaimer and agree to its terms. If you do not consent to this policy, please cease using our prompt generator.
        </p>

        <h2>2. Content Disclaimer</h2>
        <p>
          While we make every effort to ensure the drawing prompts generated are creative, positive, and appropriate for artists of all ages, Drawing Prompt Generator makes no representations or warranties of any kind, express or implied, about the completeness, accuracy, reliability, suitability, or availability of the text generated. Any reliance you place on such prompts is strictly at your own risk.
        </p>
        <p>
          Some prompts may dynamically combine historical figures, mythology, weapons, horror themes, or fantasy tropes. These combinations are procedurally generated for artistic fiction and visual illustration reference and do not represent real-world facts or promote violence or illegal activities.
        </p>

        <h2>3. External Links Disclaimer</h2>
        <p>
          From our website, you may visit external websites (like reference repositories, drawing platforms, or social media sites) by following hyperlinks. While we strive to provide only quality links to useful and ethical websites, we have no control over the content and nature of these external sites. These links to other websites do not imply a recommendation for all the content found on these sites.
        </p>

        <h2>4. Trademark Disclaimer</h2>
        <p>
          Any brand names, franchise names (like Star Wars, Cyberpunk, D&D, etc.), or product references mentioned in generated prompts are trademarks of their respective owners. Their mention in artistic prompts is strictly for stylistic/descriptive illustration contexts and does not imply endorsement, affiliation, or authorization by the trademark holders.
        </p>

        <h2>5. Contact Information</h2>
        <p>
          If you require any more information or have any questions about our site's disclaimer, please feel free to contact us by email at <a href="mailto:disclaimer@drawingpromptgenerator.com">disclaimer@drawingpromptgenerator.com</a>.
        </p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .legal-page {
    padding: 60px 0 80px 0;
  }

  .container-narrow {
    max-width: 800px;
  }

  .legal-header {
    margin-bottom: 40px;
  }

  .legal-title {
    font-size: 2.75rem;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .legal-subtitle {
    font-size: 0.95rem;
    color: var(--text-light);
  }

  .legal-content-card {
    padding: 40px;
  }

  .legal-content-card h2 {
    font-size: 1.35rem;
    margin-top: 32px;
    margin-bottom: 12px;
    color: var(--text);
  }

  .legal-content-card p {
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 16px;
    color: var(--text-muted);
  }

  .legal-content-card ul {
    margin-bottom: 16px;
    padding-left: 24px;
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .legal-content-card li {
    margin-bottom: 8px;
  }

  @media (max-width: 640px) {
    .legal-content-card {
      padding: 24px 16px;
    }
    
    .legal-title {
      font-size: 2.25rem;
    }
  }
</style>
